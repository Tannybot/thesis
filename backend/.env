# Application Settings
APP_NAME=LivestockTracker
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=sqlite:///./livestock.db

# JWT Settings
SECRET_KEY=your-super-secret-key-change-in-production-abc123def456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:5173

# QR Code Settings
QR_CODE_BASE_URL=http://192.168.1.2:5173/animals
