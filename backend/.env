# Application Settings
APP_NAME=LivestockTracker
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@db:5432/livetrack

# JWT Settings
SECRET_KEY=your-secure-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=https://livetrack.com

# QR Code Settings
QR_CODE_BASE_URL=https://livetrack.com/animals
